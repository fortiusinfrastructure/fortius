{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "globalEnv": [
    "SUPABASE_SERVICE_ROLE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_ORG_SLUG",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_PRICE_CONSULTING_SOCIEDAD_CIVIL_BASICA_MONTHLY",
    "STRIPE_PRICE_CONSULTING_SOCIEDAD_CIVIL_BASICA_ANNUAL",
    "STRIPE_PRICE_CONSULTING_SOCIEDAD_CIVIL_PREMIUM_MONTHLY",
    "STRIPE_PRICE_CONSULTING_SOCIEDAD_CIVIL_PREMIUM_ANNUAL",
    "STRIPE_PRICE_CONSULTING_POLITICA_BASICA_MONTHLY",
    "STRIPE_PRICE_CONSULTING_POLITICA_BASICA_ANNUAL",
    "STRIPE_PRICE_CONSULTING_POLITICA_PREMIUM_MONTHLY",
    "STRIPE_PRICE_CONSULTING_POLITICA_PREMIUM_ANNUAL",
    "APPROVAL_SECRET",
    "APPROVER_EMAIL",
    "STRIPE_PRICE_ACADEMICO_MONTHLY",
    "STRIPE_PRICE_ACADEMICO_ANNUAL",
    "STRIPE_PRICE_AMIGO_MONTHLY",
    "STRIPE_PRICE_MECENAS_ANNUAL",
    "CRON_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    }
  }
}